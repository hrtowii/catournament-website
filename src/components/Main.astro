            <img src="https://upload.wikimedia.org/wikipedia/commons/thumb/c/c0/VIRTU_Financial_Logo.svg/250px-VIRTU_Financial_Logo.svg.png"/>
          </div>
          <div class="sponsor-logo inset">
            <img src="https://upload.wikimedia.org/wikipedia/commons/3/3b/HRT_Primary_Logo_-_Full_Color.png"/>
          </div>
        </div>
      </div>
      <div class="sponsor-group">
        <span class="sponsor-label">Infrastructure Partners</span>
        <div class="sponsor-logos">
          <div class="sponsor-logo inset">
