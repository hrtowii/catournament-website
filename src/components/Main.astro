</main>

<script>
  const icons = [
    'chip.PNG', 'chrome.PNG', 'cloud.PNG', 'cursor.PNG', 'dvd.PNG',
    'folder.PNG', 'paws.PNG', 'screen.PNG', 'sound.PNG', 'trash.PNG'
  ];

  function shuffle<T>(arr: T[]): T[] {
    const a = [...arr];
    for (let i = a.length - 1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i + 1));
      [a[i], a[j]] = [a[j], a[i]];
    }
    return a;
  }

  function trimCanvas(src: string): Promise<string> {
    return new Promise(resolve => {
      const img = new Image();
      img.onload = () => {
        const c = document.createElement('canvas');
        c.width = img.width;
        c.height = img.height;
        const ctx = c.getContext('2d')!;
        ctx.drawImage(img, 0, 0);
        const { data, width, height } = ctx.getImageData(0, 0, c.width, c.height);
        let top = height, bottom = 0, left = width, right = 0;
        for (let y = 0; y < height; y++) {
          for (let x = 0; x < width; x++) {
            const a = data[(y * width + x) * 4 + 3];
            const r = data[(y * width + x) * 4];
            const g = data[(y * width + x) * 4 + 1];
            const b = data[(y * width + x) * 4 + 2];
            const isBlank = a < 10 || (r > 245 && g > 245 && b > 245);
            if (!isBlank) {
              if (y < top) top = y;
              if (y > bottom) bottom = y;
              if (x < left) left = x;
              if (x > right) right = x;
            }
          }
        }
        const pad = 4;
        top = Math.max(0, top - pad);
        left = Math.max(0, left - pad);
        bottom = Math.min(height - 1, bottom + pad);
        right = Math.min(width - 1, right + pad);
        const trimW = right - left + 1;
        const trimH = bottom - top + 1;
        const out = document.createElement('canvas');
        out.width = trimW;
        out.height = trimH;
        out.getContext('2d')!.drawImage(c, left, top, trimW, trimH, 0, 0, trimW, trimH);
        resolve(out.toDataURL());
      };
      img.src = src;
    });
  }

  const container = document.getElementById('meow-icons');
  if (container) {
    const picked = shuffle(icons).slice(0, 8);
    picked.forEach(name => {
      const img = document.createElement('img');
      img.alt = name.replace(/\.[^.]+$/, '');
      container.appendChild(img);
      trimCanvas(`/icons/${name}`).then(url => { img.src = url; });
    });
  }
</script>
