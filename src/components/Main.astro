        </div>
        <div class="right-thing">
          <div class="blank"></div>
<img src="/kucingfull.png" height="200px"/>
        </div>
      </div>
      <h4>+ transport / accomodation for 30 finalists</h4>

		</Window>
    <div class="image-below-space">
      <Window title="meow!">
