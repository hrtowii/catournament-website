---
interface Props {
  title?: string;
}

const { title = '' } = Astro.props;
---

<div class="window-outer">
  <div class="window-mid">
    <div class="window-inner">
      <div class="window-titlebar">
        <div class="window-controls">
          <span class="win-btn win-btn-close"    title="Close"></span>
          <span class="win-btn win-btn-minimize"  title="Minimize"></span>
          <span class="win-btn win-btn-fullscreen" title="Fullscreen"></span>
        </div>
        {title && <span class="window-title">{title}</span>}
        <div class="window-controls-spacer" aria-hidden="true"></div>
      </div>
      <div class="window-body">
        <slot />
      </div>
    </div>
  </div>
</div>

<style>
  .window-controls-spacer {
    width: 46px;
    flex-shrink: 0;
  }
</style>
